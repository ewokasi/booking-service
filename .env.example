POSTGRES_USER=booking
POSTGRES_PASSWORD=booking
POSTGRES_DB=booking
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://booking:booking@postgres:5432/booking
ALEMBIC_DATABASE_URL=postgresql://booking:booking@postgres:5432/booking

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

WORKER_FAILURE_RATE=0.15
WORKER_MAX_RETRIES=3
WORKER_RETRY_BACKOFF=2

APP_ENV=local
LOG_LEVEL=INFO
RATE_LIMIT_CREATE_BOOKING=10/minute
